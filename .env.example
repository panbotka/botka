# Server
PORT=5110

# Database
DATABASE_URL=postgres://botka:botka@localhost:5432/botka?sslmode=disable

# Projects
PROJECTS_DIR=/home/pi/projects

# Claude
CLAUDE_PATH=claude
CLAUDE_USAGE_CMD=/home/pi/bin/claude-usage
CLAUDE_CONTEXT_DIR=./data/context
CLAUDE_DEFAULT_WORK_DIR=/home/pi

# Task Runner
MAX_WORKERS=2
USAGE_THRESHOLD_5H=0.90
USAGE_THRESHOLD_7D=0.95

# OpenClaw
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=
OPENCLAW_WORKSPACE=/home/pi/.openclaw/workspace

# Chat
WHISPER_ENABLED=true
UPLOAD_DIR=./data/uploads

# AI
AI_MODEL=sonnet
AVAILABLE_MODELS=sonnet,opus,haiku

# Authentication
WEBAUTHN_ORIGIN=http://localhost:5110
# WEBAUTHN_RPID=           # Derived from origin if unset
SESSION_MAX_AGE=720h

# MCP
# MCP_TOKEN=               # Bearer token for SSE transport (empty = SSE disabled)

# Box Server
# BOX_HOST=100.127.79.1
# BOX_SSH_USER=box
# BOX_WOL_COMMAND=/home/pi/bin/boxon

# Keepalive
KEEPALIVE_ENABLED=true
KEEPALIVE_INTERVAL=60m
